<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!--
        WalkSafe local development network security config.
        Permits cleartext (plain HTTP) traffic to local development addresses only.
        10.0.2.2    = Android emulator loopback to host machine
        10.0.3.2    = Genymotion emulator loopback to host machine
        127.0.0.1   = localhost
        192.168.0.0/16 = typical LAN range for physical device testing
        This file must NOT be used in production builds.
        Production builds must use HTTPS exclusively.
    -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">10.0.2.2</domain>
        <domain includeSubdomains="false">10.0.3.2</domain>
        <domain includeSubdomains="false">127.0.0.1</domain>
        <domain includeSubdomains="false">localhost</domain>
    </domain-config>
</network-security-config>
